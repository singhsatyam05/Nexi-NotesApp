import 'dart:convert';
import 'dart:io';
import 'package:path_provider/path_provider.dart';
import '../models/note.dart';

class NotesService {
  static const String _notesFileName = 'nexii_notes.json';
  
  // Encrypt the notes data before saving
  String _encrypt(String data, String password) {
    // Simple XOR encryption for demo - in production, use AES
    List<int> dataBytes = utf8.encode(data);
    List<int> keyBytes = utf8.encode(password);
    
    List<int> encrypted = [];
    for (int i = 0; i < dataBytes.length; i++) {
      encrypted.add(dataBytes[i] ^ keyBytes[i % keyBytes.length]);
    }
    
    return base64.encode(encrypted);
  }
  
  // Decrypt the notes data after loading
  String _decrypt(String encryptedData, String password) {
    try {
      List<int> encrypted = base64.decode(encryptedData);
      List<int> keyBytes = utf8.encode(password);
      
      List<int> decrypted = [];
      for (int i = 0; i < encrypted.length; i++) {
        decrypted.add(encrypted[i] ^ keyBytes[i % keyBytes.length]);
      }
      
      return utf8.decode(decrypted);
    } catch (e) {
      throw Exception('Failed to decrypt notes: $e');
    }
  }

  // No permission needed for internal app storage
  Future<bool> _requestStoragePermission() async {
    return true; // App internal storage doesn't need permissions
  }

  // Get the notes file path
  Future<String> _getNotesFilePath() async {
    final directory = await getApplicationDocumentsDirectory();
    return '${directory.path}/$_notesFileName';
  }

  // Load all notes from encrypted file
  Future<List<Note>> loadNotes(String password) async {
    try {
      final filePath = await _getNotesFilePath();
      final file = File(filePath);
      
      if (!await file.exists()) {
        return []; // Return empty list if file doesn't exist
      }
      
      final encryptedContent = await file.readAsString();
      final decryptedContent = _decrypt(encryptedContent, password);
      
      final Map<String, dynamic> data = json.decode(decryptedContent);
      final List<dynamic> notesJson = data['notes'] ?? [];
      
      return notesJson.map((noteJson) => Note.fromJson(noteJson)).toList();
    } catch (e) {
      throw Exception('Failed to load notes: $e');
    }
  }

  // Save all notes to encrypted file
  Future<void> saveNotes(List<Note> notes, String password) async {
    try {
      // Request permission first
      final hasPermission = await _requestStoragePermission();
      if (!hasPermission) {
        throw Exception('Storage permission denied');
      }
      
      final filePath = await _getNotesFilePath();
      final file = File(filePath);
      
      // Create the data structure
      final Map<String, dynamic> data = {
        'version': '1.0',
        'timestamp': DateTime.now().toIso8601String(),
        'notes': notes.map((note) => note.toJson()).toList(),
      };
      
      final jsonContent = json.encode(data);
      final encryptedContent = _encrypt(jsonContent, password);
      
      await file.writeAsString(encryptedContent);
    } catch (e) {
      throw Exception('Failed to save notes: $e');
    }
  }

  // Add a new note
  Future<void> addNote(Note note, List<Note> currentNotes, String password) async {
    currentNotes.add(note);
    await saveNotes(currentNotes, password);
  }

  // Update an existing note
  Future<void> updateNote(Note updatedNote, List<Note> currentNotes, String password) async {
    final index = currentNotes.indexWhere((note) => note.id == updatedNote.id);
    if (index != -1) {
      currentNotes[index] = updatedNote;
      await saveNotes(currentNotes, password);
    } else {
      throw Exception('Note not found');
    }
  }

  // Delete a note
  Future<void> deleteNote(String noteId, List<Note> currentNotes, String password) async {
    currentNotes.removeWhere((note) => note.id == noteId);
    await saveNotes(currentNotes, password);
  }

  // Get notes file info
  Future<Map<String, dynamic>> getNotesFileInfo() async {
    try {
      final filePath = await _getNotesFilePath();
      final file = File(filePath);
      
      if (!await file.exists()) {
        return {
          'exists': false,
          'path': filePath,
          'size': 0,
          'lastModified': null,
        };
      }
      
      final stat = await file.stat();
      return {
        'exists': true,
        'path': filePath,
        'size': stat.size,
        'lastModified': stat.modified,
      };
    } catch (e) {
      throw Exception('Failed to get file info: $e');
    }
  }

  // Check if the password can decrypt existing notes
  Future<bool> validatePassword(String password) async {
    try {
      await loadNotes(password);
      return true;
    } catch (e) {
      return false;
    }
  }
}
